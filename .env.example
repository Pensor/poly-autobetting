# Credentials
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_FUNDER=0xYOUR_FUNDER_ADDRESS_HERE

# Builder Relayer (gasless on-chain transactions)
POLYMARKET_BUILDER_API_KEY=YOUR_BUILDER_API_KEY
POLYMARKET_BUILDER_SECRET=YOUR_BUILDER_SECRET
POLYMARKET_BUILDER_PASSPHRASE=YOUR_BUILDER_PASSPHRASE

# Session defaults
BOT_SESSION_CAPITAL_LIMIT=100
BOT_SHARES_PER_ORDER=10

# Risk limits
BOT_DAILY_LOSS_LIMIT=25
BOT_HOURLY_LOSS_LIMIT=15
BOT_WORST_CASE_PNL_LIMIT=-100
BOT_UNHEDGED_EXPOSURE_LIMIT=30

# Entry / VWAP
BOT_MAX_TRADES=120
BOT_ENTRY_MAX_EXPECTED_COMBINED=1.010

# Features
BOT_SMART_CANCEL_ENABLED=1
BOT_PASSIVE_EXPANSION_ENABLED=0
